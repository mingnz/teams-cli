{
  "name": "teams-cli",
  "version": "0.1.0",
  "description": "CLI for Microsoft Teams — list chats, read and send messages, search, and more.",
  "type": "module",
  "bin": {
    "teams": "dist/index.js",
    "teams-cli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "npx playwright install chromium",
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "format": "biome format --write src tests"
  },
  "keywords": [
    "microsoft-teams",
    "teams",
    "cli",
    "chat",
    "messaging",
    "automation",
    "ai-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mingnz/teams-cli.git"
  },
  "main": "dist/index.js",
  "directories": {
    "test": "tests"
  },
  "author": "mingnz",
  "bugs": {
    "url": "https://github.com/mingnz/teams-cli/issues"
  },
  "homepage": "https://github.com/mingnz/teams-cli#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
